<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zs Control Pro</title>

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: Arial, sans-serif; }

    body {
      background: #f7f7f7;
      color: #333;
    }

    header {
      background: #d90429;
      color: white;
      padding: 18px;
      text-align: center;
    }

    header h1 {
      font-size: 22px;
    }

    header span {
      font-size: 26px;
    }

    main {
      max-width: 600px;
      margin: auto;
      padding: 16px;
    }

    .card {
      background: white;
      border-radius: 14px;
      padding: 16px;
      margin-bottom: 16px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .card h2 {
      margin-bottom: 10px;
      font-size: 18px;
    }

    input {
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: 1px solid #ccc;
      margin-bottom: 10px;
      font-size: 14px;
    }

    button {
      width: 100%;
      padding: 12px;
      border-radius: 10px;
      border: none;
      font-size: 15px;
      cursor: pointer;
      background: #d90429;
      color: white;
      font-weight: bold;
    }

    .search {
      margin-bottom: 10px;
    }

    .prod-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      border-radius: 10px;
      margin-bottom: 8px;
      background: #fafafa;
      border-left: 6px solid #ccc;
    }

    .ok { border-color: #2ecc71; }
    .perto { border-color: #f1c40f; }
    .vencido { border-color: #e74c3c; animation: piscar 1s infinite; }

    @keyframes piscar {
      0% { opacity: 1; }
      50% { opacity: 0.4; }
      100% { opacity: 1; }
    }

    .status {
      font-size: 12px;
      font-weight: bold;
    }

    .remove {
      background: #e74c3c;
      padding: 6px 10px;
      font-size: 12px;
      margin-top: 5px;
    }

    .categoria {
      font-size: 11px;
      color: #777;
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }

    .contador {
      font-size: 13px;
      color: #555;
    }

  </style>
</head>

<body>

<header>
  <h1>❤️ Zs Control Pro</h1>
  <p>Controle profissional de validade</p>
</header>

<main>

  <div class="card">
    <h2>Cadastrar Produto</h2>

    <input id="nome" placeholder="Nome do produto" />
    <input id="categoria" placeholder="Categoria (bebida, limpeza...)" />
    <input id="data" type="date" />

    <button onclick="adicionar()">Cadastrar</button>
  </div>

  <div class="card">

    <div class="top-bar">
      <h2>Produtos</h2>
      <div class="contador" id="contador"></div>
    </div>

    <input id="busca" class="search" placeholder="Buscar produto..." oninput="render()" />

    <div id="lista"></div>

  </div>

</main>

<script>

let produtos = JSON.parse(localStorage.getItem('zs_pro') || '[]');

function salvar() {
  localStorage.setItem('zs_pro', JSON.stringify(produtos));
}

function dias(data) {
  const hoje = new Date();
  hoje.setHours(0,0,0,0);
  const d = new Date(data);
  d.setHours(0,0,0,0);
  return Math.ceil((d - hoje)/(1000*60*60*24));
}

function adicionar() {
  const nome = document.getElementById('nome').value;
  const categoria = document.getElementById('categoria').value;
  const data = document.getElementById('data').value;

  if(!nome || !data) {
    alert('Preencha os campos');
    return;
  }

  produtos.push({nome, categoria, data});

  document.getElementById('nome').value = '';
  document.getElementById('categoria').value = '';
  document.getElementById('data').value = '';

  salvar();
  render();
}

function remover(i) {
  produtos.splice(i,1);
  salvar();
  render();
}

function render() {
  const lista = document.getElementById('lista');
  const busca = document.getElementById('busca').value.toLowerCase();

  lista.innerHTML = '';

  let filtrados = produtos.filter(p => p.nome.toLowerCase().includes(busca));

  filtrados.sort((a,b)=> new Date(a.data)-new Date(b.data));

  document.getElementById('contador').innerText = filtrados.length + ' itens';

  filtrados.forEach((p,i)=>{
    const d = dias(p.data);

    let classe = 'ok';
    let status = '';

    if(d < 0){ classe='vencido'; status='VENCIDO'; }
    else if(d <= 3){ classe='perto'; status='Vence em '+d+'d'; }
    else { status='Ok ('+d+'d)'; }

    const div = document.createElement('div');
    div.className = 'prod-item '+classe;

    div.innerHTML = `
      <div>
        <strong>${p.nome}</strong><br>
        <span class="categoria">${p.categoria || ''}</span><br>
        <small>${new Date(p.data).toLocaleDateString('pt-BR')}</small>
      </div>
      <div>
        <div class="status">${status}</div>
        <button class="remove" onclick="remover(${i})">Remover</button>
      </div>
    `;

    lista.appendChild(div);
  });
}

render();

</script>

</body>
</html>
