<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zs Control Pro</title>

<style>
body {
  margin:0;
  font-family: Arial;
  background:#121212;
  color:white;
}

header {
  background:#16a34a;
  padding:20px;
  font-size:22px;
  font-weight:bold;
}

main {
  padding:15px;
  max-width:500px;
  margin:auto;
}

.card {
  background:#1e1e1e;
  padding:15px;
  border-radius:15px;
  margin-bottom:15px;
}

input, select {
  width:100%;
  padding:12px;
  margin-bottom:10px;
  border:none;
  border-radius:10px;
  background:#2a2a2a;
  color:white;
}

button {
  width:100%;
  padding:12px;
  border:none;
  border-radius:10px;
  background:#16a34a;
  color:white;
  font-weight:bold;
}

.prod {
  background:#2a2a2a;
  padding:12px;
  border-radius:12px;
  margin-bottom:10px;
  display:flex;
  justify-content:space-between;
}

.vencido {border-left:5px solid red;}
.perto {border-left:5px solid yellow;}
.ok {border-left:5px solid green;}

.status {font-size:12px;}

.top {
  display:flex;
  justify-content:space-between;
  margin-bottom:10px;
  font-size:13px;
}

.remove {
  background:red;
  margin-top:5px;
  font-size:12px;
}
</style>
</head>

<body>

<header>Zs Control Pro</header>

<main>

<div class="card">
<h3>Cadastrar Produto</h3>
<input id="nome" placeholder="Nome">
<input id="categoria" placeholder="Categoria">
<input id="data" type="date">
<button onclick="add()">Cadastrar</button>
</div>

<div class="card">

<div class="top">
<span id="total"></span>
<span id="vencidos"></span>
<span id="perto"></span>
</div>

<input id="busca" placeholder="Buscar..." oninput="render()">

<select id="filtro" onchange="render()">
<option value="">Todos</option>
<option value="vencido">Vencidos</option>
<option value="perto">Próximos</option>
<option value="ok">OK</option>
</select>

<div id="lista"></div>

</div>

<div class="card">
<h3>Sobre</h3>
<p>Zs Control Pro</p>
<p style="color:#16a34a">Termos • Privacidade</p>
</div>

</main>

<script>

let produtos = JSON.parse(localStorage.getItem('zs')||'[]');

function save(){
 localStorage.setItem('zs',JSON.stringify(produtos));
}

function dias(d){
 let hoje=new Date(); hoje.setHours(0,0,0,0);
 let dt=new Date(d); dt.setHours(0,0,0,0);
 return Math.ceil((dt-hoje)/(1000*60*60*24));
}

function add(){
 let nome=nomeEl.value;
 let cat=categoriaEl.value;
 let data=dataEl.value;

 if(!nome||!data) return alert("Preencha");

 produtos.push({nome,cat,data});
 nomeEl.value=""; categoriaEl.value=""; dataEl.value="";
 save(); render();
}

function remove(i){
 produtos.splice(i,1);
 save(); render();
}

function render(){

 let busca=document.getElementById("busca").value.toLowerCase();
 let filtro=document.getElementById("filtro").value;

 let lista=document.getElementById("lista");
 lista.innerHTML="";

 let v=0,p=0,o=0;

 let filtrados=produtos.filter(x=>x.nome.toLowerCase().includes(busca));

 filtrados.sort((a,b)=> new Date(a.data)-new Date(b.data));

 filtrados.forEach((x,i)=>{

  let d=dias(x.data);
  let cls="ok", txt="OK";

  if(d<0){cls="vencido";txt="VENCIDO";v++;}
  else if(d<=3){cls="perto";txt="Vence em "+d+"d";p++;}
  else{o++;}

  if(filtro && filtro!=cls) return;

  let div=document.createElement("div");
  div.className="prod "+cls;

  div.innerHTML=`
  <div>
  <b>${x.nome}</b><br>
  <small>${x.cat||""}</small><br>
  <small>${new Date(x.data).toLocaleDateString()}</small>
  </div>

  <div>
  <div class="status">${txt}</div>
  <button class="remove" onclick="remove(${i})">Remover</button>
  </div>
  `;

  lista.appendChild(div);

 });

 total.innerText="Total: "+filtrados.length;
 vencidos.innerText="Vencidos: "+v;
 perto.innerText="Próx: "+p;

}

const nomeEl=document.getElementById("nome");
const categoriaEl=document.getElementById("categoria");
const dataEl=document.getElementById("data");

render();

</script>

</body>
</html>
